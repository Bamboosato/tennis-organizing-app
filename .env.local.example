# Firebase Web SDK
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK
# Not required by tennis-organizing-app ver1.00.
# These values are maintained in tennis-matchup-app for admin login and API auth.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# tennis-matchup-app API
MATCHUP_API_BASE_URL=https://tennis-matchup-app.vercel.app
# Local and production use the same tennis-matchup-app API key unless explicitly rotated.
MATCHUP_API_KEY=

# Optional for calling protected Vercel preview deployments
VERCEL_AUTOMATION_BYPASS_SECRET=
